{
  "name": "@li-langverse/li-research-ingest",
  "version": "0.3.0-r1b",
  "description": "Li research warm-index bulk ingest — R1b orchestrator + S2/arXiv staging",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "bin": {
    "li-research-ingest": "./dist/cli.js"
  },
  "scripts": {
